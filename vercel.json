{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/website/index.html" },
    { "source": "/index.html", "destination": "/website/index.html" },
    { "source": "/css/:path*", "destination": "/website/css/:path*" },
    { "source": "/js/:path*", "destination": "/website/js/:path*" },
    { "source": "/images/:path*", "destination": "/website/images/:path*" },
    { "source": "/tours", "destination": "/website/tours.html" },
    { "source": "/about", "destination": "/website/about.html" },
    { "source": "/contact", "destination": "/website/contact.html" },
    { "source": "/destinations", "destination": "/website/destinations.html" },
    { "source": "/hotels", "destination": "/website/hotels.html" },
    { "source": "/tour-detail", "destination": "/website/tour-detail.html" }
  ]
}
