{
  "cleanUrls": false,
  "rewrites": [
    { "source": "/", "destination": "/website/index.html" },
    { "source": "/index.html", "destination": "/website/index.html" },
    { "source": "/css/:path*", "destination": "/website/css/:path*" },
    { "source": "/js/:path*", "destination": "/website/js/:path*" },
    { "source": "/images/:path*", "destination": "/website/images/:path*" },
    { "source": "/tours/:slug", "destination": "/website/tour-detail.html" },
    { "source": "/tours", "destination": "/website/tours.html" },
    { "source": "/tours.html", "destination": "/website/tours.html" },
    { "source": "/about", "destination": "/website/about.html" },
    { "source": "/about.html", "destination": "/website/about.html" },
    { "source": "/contact", "destination": "/website/contact.html" },
    { "source": "/contact.html", "destination": "/website/contact.html" },
    { "source": "/destinations", "destination": "/website/destinations.html" },
    { "source": "/destinations.html", "destination": "/website/destinations.html" },
    { "source": "/hotels", "destination": "/website/hotels.html" },
    { "source": "/hotels.html", "destination": "/website/hotels.html" },
    { "source": "/cars", "destination": "/website/cars.html" },
    { "source": "/cars.html", "destination": "/website/cars.html" },
    { "source": "/tour-detail", "destination": "/website/tour-detail.html" },
    { "source": "/tour-detail.html", "destination": "/website/tour-detail.html" },
    { "source": "/blog", "destination": "/website/blog.html" },
    { "source": "/blog.html", "destination": "/website/blog.html" },
    { "source": "/blog-detail", "destination": "/website/blog-detail.html" },
    { "source": "/blog-detail.html", "destination": "/website/blog-detail.html" },
    { "source": "/hotel-detail", "destination": "/website/hotel-detail.html" },
    { "source": "/hotel-detail.html", "destination": "/website/hotel-detail.html" },
    { "source": "/privacy", "destination": "/website/privacy.html" },
    { "source": "/privacy.html", "destination": "/website/privacy.html" },
    { "source": "/terms", "destination": "/website/terms.html" },
    { "source": "/terms.html", "destination": "/website/terms.html" },
    { "source": "/sitemap", "destination": "/website/sitemap.html" },
    { "source": "/sitemap.html", "destination": "/website/sitemap.html" }
  ]
}
